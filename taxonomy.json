import pandas as pd
import json

def convert_percorsi_to_json(csv_filepath, json_filepath):
    """
    Transforms the Regione Piemonte 'Percorsi standard' CSV into a clean JSON structure.
    """
    # Load CSV, treating everything as strings to prevent ID truncation
    df = pd.read_csv(csv_filepath, dtype=str)
    
    # Clean up column headers (remove invisible spaces and newlines)
    df.columns = [col.strip().replace('\n', ' ') for col in df.columns]
    
    # Replace Pandas NaN values with standard JSON nulls
    df = df.where(pd.notnull(df), None)
    
    # Convert the dataframe to a list of dictionaries
    records = df.to_dict(orient='records')
    
    # Wrap in a root object and export
    output_data = {"percorsi_standard": records}
    
    with open(json_filepath, 'w', encoding='utf-8') as f:
        json.dump(output_data, f, indent=2, ensure_ascii=False)
        
    print(f"Success: {len(records)} training paths exported to {json_filepath}")

if __name__ == "__main__":
    # Ensure this matches your extracted CSV filename
    input_file = "Estrazione_percorsi_standard_19-03-2026_14.09.xlsx - Percorsi standard.csv"
    output_file = "percorsi_standard.json"
    
    convert_percorsi_to_json(input_file, output_file)
